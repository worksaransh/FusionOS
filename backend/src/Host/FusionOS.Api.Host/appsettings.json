{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "TopicPrefix": "fusionos"
  },
  "Jwt": {
    "Issuer": "fusionos",
    "Audience": "fusionos-clients",
    "SigningKey": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIPHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "*", "Period": "1s", "Limit": 10 },
      { "Endpoint": "*", "Period": "15m", "Limit": 300 },
      { "Endpoint": "post:/api/v1/core/auth/login", "Period": "1m", "Limit": 5 },
      { "Endpoint": "post:/api/v1/core/auth/refresh", "Period": "1m", "Limit": 10 },
      { "Endpoint": "post:/api/v1/core/auth/register", "Period": "1h", "Limit": 10 }
    ]
  },
  "Observability": {
    "OtlpEndpoint": "",
    "LokiUrl": ""
  }
}
